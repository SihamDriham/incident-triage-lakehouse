# Copier ce fichier vers ~/.dbt/profiles.yml et remplir les valeurs.
# Ne jamais committer le vrai profiles.yml (il est dans .gitignore).

pfe_spark_triage:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: "{{ env_var('SNOWFLAKE_ACCOUNT') }}"
      user: "{{ env_var('SNOWFLAKE_USER') }}"
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"
      role: "{{ env_var('SNOWFLAKE_ROLE', 'SYSADMIN') }}"
      database: "{{ env_var('SNOWFLAKE_DATABASE', 'PFE_SPARK') }}"
      warehouse: "{{ env_var('SNOWFLAKE_WAREHOUSE', 'PFE_WH') }}"
      schema: public
      threads: 4
      client_session_keep_alive: false
      query_tag: dbt_pfe_spark
